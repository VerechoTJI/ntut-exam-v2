{
  "name": "test-system-host",
  "private": true,
  "scripts": {
    "dev:backend": "pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "build:backend": "pnpm --filter backend build",
    "build:frontend": "pnpm --filter frontend build",
    "build": "pnpm build:backend && pnpm build:frontend",
    "start:backend": "pnpm --filter backend start",
    "start:frontend": "pnpm --filter frontend start",
    "start": "pnpm --parallel --filter backend --filter frontend start",
    "production": "pnpm build && pnpm start"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "special-rule-engine",
      "sqlite3"
    ]
  },
  "version": "0.5.0"
}